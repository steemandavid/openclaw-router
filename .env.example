# OpenClaw LLM Router Configuration

# z.ai API key (required for medium/complex tiers)
# Get one at https://z.ai
ZAI_API_KEY=your-zai-api-key-here

# Optional: bearer token to require on /v1/* requests.
# Leave empty to disable auth (LAN-only deployments).
ROUTER_API_KEY=

# Provider URLs
OLLAMA_BASE_URL=http://192.168.1.165:11434
# z.ai only ships an Anthropic-compatible API — the router translates
# OpenAI ⇄ Anthropic Messages format transparently.
ZAI_BASE_URL=https://api.z.ai/api/anthropic

# Classifier model (runs on Ollama)
# Default unifies classifier + simple tier on one 23GB model so it stays
# pinned in VRAM and never gets swapped. See CLASSIFIER_AND_ROUTING_DESIGN.md.
CLASSIFIER_MODEL=qwen2.5:32b-instruct-q4_K_M
CLASSIFIER_BASE_URL=http://192.168.1.165:11434
CLASSIFIER_TIMEOUT=15

# Model assignments per tier
SIMPLE_MODEL=qwen2.5:32b-instruct-q4_K_M
MEDIUM_MODEL=claude-sonnet-4-6-20250514
COMPLEX_MODEL=claude-sonnet-4-6-20250514

# Hard cap on simple-tier max_tokens (defends against degenerate local-model
# loops — see the spam incident in the changelog).
SIMPLE_MAX_TOKENS=512

# Timeouts
UPSTREAM_TIMEOUT=180

# Server
PORT=4100
LOG_LEVEL=INFO
